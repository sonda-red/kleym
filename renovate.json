{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:all"
  ],
  "automerge": true,
  "platformAutomerge": true,
  "automergeType": "pr",
  "packageRules": [
    {
      "description": "Go version comes from go.mod via setup-go",
      "matchManagers": [
        "github-actions",
        "docker"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "golang"
      ],
      "matchFileNames": [
        ".github/workflows/*.yml"
      ],
      "enabled": false
    }
  ]
}

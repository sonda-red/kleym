{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    "group:all"
  ],
  "automerge": false,
  "platformAutomerge": false,
  "automergeType": "pr",
  "packageRules": [
    {
      "description": "Automerge patch and minor updates only",
      "matchUpdateTypes": [
        "patch",
        "minor"
      ],
      "automerge": true,
      "platformAutomerge": true,
      "automergeType": "pr"
    },
    {
      "description": "Go version comes from go.mod via setup-go",
      "matchManagers": [
        "github-actions",
        "docker"
      ],
      "matchDatasources": [
        "docker"
      ],
      "matchPackageNames": [
        "golang"
      ],
      "matchFileNames": [
        ".github/workflows/*.yml"
      ],
      "enabled": false
    }
  ]
}
